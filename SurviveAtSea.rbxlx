          <string name="Name">Config</string>
          <string name="Source"><![CDATA[-- Survive at Sea shared configuration
-- Session state is intentionally ephemeral (no DataStores / caching).

local Config = {
	GameName = "Survive at Sea",
	Tagline = "Gather your crew. Board the voyage. Survive the deep.",

	-- Party / server limits (Dead Rails-style: 1–10 players per run)
	MinPartySize = 1,
	MaxPartySize = 10,
	DefaultPartySize = 4,
	LaunchCountdownSeconds = 10,

	-- Set this to your voyage PlaceId when the sea run place exists.
	-- Until then, parties launch into the in-place VoyageStaging zone.
	GamePlaceId = nil :: number?,

	-- Lobby layout (portals close to spawn so they're obvious)
	LobbyCenter = Vector3.new(0, 4, 0),
	PortalCount = 3,
	PortalSpacing = 24,

	-- Ocean theme palette
	Theme = {
		DeepOcean = Color3.fromRGB(8, 32, 58),
		SeaTeal = Color3.fromRGB(18, 110, 130),
		Foam = Color3.fromRGB(210, 235, 240),
		Driftwood = Color3.fromRGB(92, 64, 42),
		Rope = Color3.fromRGB(160, 120, 70),
		Lantern = Color3.fromRGB(255, 186, 90),
		PortalGlow = Color3.fromRGB(60, 200, 190),
		DangerRed = Color3.fromRGB(220, 70, 70),
		UIPanel = Color3.fromRGB(10, 28, 42),
		UIAccent = Color3.fromRGB(46, 180, 170),
		UIText = Color3.fromRGB(235, 248, 250),
		UIMuted = Color3.fromRGB(150, 185, 195),
	},

	-- Cross-platform UI scale targets
	UI = {
		MinTouchTarget = 48,
		SafePadding = 16,
		Font = Enum.Font.GothamBold,
		BodyFont = Enum.Font.GothamMedium,
	},
}

return Config
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="4">
        <Properties>
          <string name="Name">LobbyWorld</string>
          <string name="Source"><![CDATA[-- Builds the Survive at Sea boarding dock in Workspace.
-- Safe to call from server (replicates) or client (local fallback).

local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")

local Config = require(script.Parent:WaitForChild("Config"))

local LobbyWorld = {}

local function part(props: { [string]: any }): Part
	local p = Instance.new("Part")
	p.Anchored = true
	p.CanCollide = if props.CanCollide == nil then true else props.CanCollide
	p.Material = props.Material or Enum.Material.WoodPlanks
	p.Color = props.Color or Config.Theme.Driftwood
	p.Size = props.Size or Vector3.new(4, 1, 4)
	p.CFrame = props.CFrame or CFrame.new()
	p.Name = props.Name or "LobbyPart"
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.CastShadow = if props.CastShadow == nil then true else props.CastShadow
	if props.Transparency ~= nil then
		p.Transparency = props.Transparency
	end
	if props.Reflectance ~= nil then
		p.Reflectance = props.Reflectance
	end
	p.Parent = props.Parent
	return p
end

local function billboard(adornee: BasePart, text: string, color: Color3, size: UDim2?, offsetY: number?)
	local gui = Instance.new("BillboardGui")
	gui.Name = "LobbyBillboard"
	gui.Adornee = adornee
	gui.Size = size or UDim2.fromOffset(280, 90)
	gui.StudsOffsetWorldSpace = Vector3.new(0, offsetY or 8, 0)
	gui.AlwaysOnTop = true
	gui.MaxDistance = 250
	gui.Parent = adornee

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 0.15
	label.BackgroundColor3 = Config.Theme.UIPanel
	label.BorderSizePixel = 0
	label.Size = UDim2.fromScale(1, 1)
	label.Font = Enum.Font.GothamBold
	label.TextScaled = true
	label.TextColor3 = color
	label.Text = text
	label.Parent = gui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = label

	local pad = Instance.new("UIPadding")
	pad.PaddingTop = UDim.new(0, 8)
	pad.PaddingBottom = UDim.new(0, 8)
	pad.PaddingLeft = UDim.new(0, 12)
	pad.PaddingRight = UDim.new(0, 12)
	pad.Parent = label

	local stroke = Instance.new("UIStroke")
	stroke.Color = Config.Theme.UIAccent
	stroke.Thickness = 2
	stroke.Parent = label
end

local function buildPortal(folder: Instance, index: number, position: Vector3): Model
	local model = Instance.new("Model")
	model.Name = "Portal_" .. index
	model.Parent = folder

	local pad = part({
		Name = "Pad",
		Parent = model,
		Size = Vector3.new(18, 1.5, 18),
		CFrame = CFrame.new(position),
		Color = Color3.fromRGB(80, 58, 36),
		Material = Enum.Material.WoodPlanks,
	})

	part({
		Name = "NeonRing",
		Parent = model,
		Size = Vector3.new(18.5, 0.6, 18.5),
		CFrame = CFrame.new(position + Vector3.new(0, 0.9, 0)),
		Color = Config.Theme.PortalGlow,
		Material = Enum.Material.Neon,
		CanCollide = false,
	})

	for _, offsetX in { -7, 7 } do
		part({
			Name = "ArchLeg",
			Parent = model,
			Size = Vector3.new(2.5, 18, 2.5),
			CFrame = CFrame.new(position + Vector3.new(offsetX, 10, 0)),
			Color = Color3.fromRGB(95, 65, 40),
			Material = Enum.Material.Wood,
		})
	end

	part({
		Name = "ArchTop",
		Parent = model,
		Size = Vector3.new(18, 2.5, 2.5),
		CFrame = CFrame.new(position + Vector3.new(0, 20, 0)),
		Color = Color3.fromRGB(95, 65, 40),
		Material = Enum.Material.Wood,
	})

	local gate = part({
		Name = "Gate",
		Parent = model,
		Size = Vector3.new(11, 15, 1.4),
		CFrame = CFrame.new(position + Vector3.new(0, 9, 0)),
		Color = Config.Theme.PortalGlow,
		Material = Enum.Material.ForceField,
		Transparency = 0.25,
		CanCollide = false,
	})

	local gateLight = Instance.new("PointLight")
	gateLight.Color = Config.Theme.PortalGlow
	gateLight.Brightness = 3
	gateLight.Range = 28
	gateLight.Parent = gate

	task.spawn(function()
		local info = TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
		TweenService:Create(gate, info, { Transparency = 0.55 }):Play()
	end)

	local promptPart = part({
		Name = "PromptAnchor",
		Parent = model,
		Size = Vector3.new(6, 6, 6),
		CFrame = CFrame.new(position + Vector3.new(0, 3, 6)),
		Transparency = 1,
		CanCollide = false,
		CastShadow = false,
	})

	local prompt = Instance.new("ProximityPrompt")
	prompt.Name = "BoardPrompt"
	prompt.ObjectText = "Voyage Portal " .. index
	prompt.ActionText = "Create Crew"
	prompt.HoldDuration = 0.25
	prompt.MaxActivationDistance = 16
	prompt.RequiresLineOfSight = false
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.Parent = promptPart

	local indexValue = Instance.new("IntValue")
	indexValue.Name = "PortalIndex"
	indexValue.Value = index
	indexValue.Parent = model

	billboard(pad, `PORTAL {index}\nWalk up · press E`, Config.Theme.Foam, UDim2.fromOffset(260, 90), 10)
	model.PrimaryPart = pad
	return model
end

function LobbyWorld.getLobbySpawnCFrame(): CFrame
	return CFrame.new(0, 6, 0)
end

function LobbyWorld.ensure(): Folder
	local existing = Workspace:FindFirstChild("SurviveAtSeaLobby")
	if existing and existing:IsA("Folder") then
		return existing
	end

	-- Hide leftover starter pads so the pier is obvious
	for _, child in Workspace:GetChildren() do
		if child:IsA("SpawnLocation") or (child:IsA("BasePart") and child.Name ~= "Terrain") then
			if child.Name ~= "SurviveAtSeaLobby" then
				child.Transparency = 1
				if child:IsA("BasePart") then
					child.CanCollide = false
				end
				if child:IsA("SpawnLocation") then
					child.Enabled = false
				end
			end
		end
	end

	local root = Instance.new("Folder")
	root.Name = "SurviveAtSeaLobby"
	root.Parent = Workspace

	part({
		Name = "OceanDeep",
		Parent = root,
		Size = Vector3.new(1200, 30, 1200),
		CFrame = CFrame.new(0, -16, 0),
		Color = Color3.fromRGB(6, 40, 70),
		Material = Enum.Material.SmoothPlastic,
		Transparency = 0.1,
	})

	part({
		Name = "OceanSurface",
		Parent = root,
		Size = Vector3.new(1200, 2, 1200),
		CFrame = CFrame.new(0, 0, 0),
		Color = Color3.fromRGB(20, 120, 150),
		Material = Enum.Material.Glass,
		Transparency = 0.45,
		Reflectance = 0.15,
		CanCollide = false,
	})

	local dock = Instance.new("Folder")
	dock.Name = "Dock"
	dock.Parent = root

	part({
		Name = "PierDeck",
		Parent = dock,
		Size = Vector3.new(80, 3, 140),
		CFrame = CFrame.new(0, 2, 20),
		Color = Color3.fromRGB(120, 82, 48),
		Material = Enum.Material.WoodPlanks,
	})

	part({
		Name = "CenterPlank",
		Parent = dock,
		Size = Vector3.new(8, 3.2, 140),
		CFrame = CFrame.new(0, 2, 20),
		Color = Color3.fromRGB(170, 120, 70),
		Material = Enum.Material.WoodPlanks,
	})

	for _, x in { -38, 38 } do
		part({
			Name = "Rail",
			Parent = dock,
			Size = Vector3.new(1.5, 4, 140),
			CFrame = CFrame.new(x, 5, 20),
			Color = Color3.fromRGB(90, 60, 35),
			Material = Enum.Material.Wood,
		})
	end

	for z = -40, 80, 20 do
		for _, x in { -30, 30 } do
			part({
				Name = "Pillar",
				Parent = dock,
				Size = Vector3.new(4, 18, 4),
				CFrame = CFrame.new(x, -5, z),
				Color = Color3.fromRGB(70, 48, 28),
				Material = Enum.Material.Wood,
			})
		end
	end

	part({
		Name = "Lighthouse",
		Parent = dock,
		Size = Vector3.new(12, 48, 12),
		CFrame = CFrame.new(-55, 25, -20),
		Color = Color3.fromRGB(240, 240, 235),
		Material = Enum.Material.SmoothPlastic,
	})
	part({
		Name = "LighthouseStripe",
		Parent = dock,
		Size = Vector3.new(12.4, 8, 12.4),
		CFrame = CFrame.new(-55, 18, -20),
		Color = Color3.fromRGB(200, 60, 55),
		Material = Enum.Material.SmoothPlastic,
	})
	local lamp = part({
		Name = "LighthouseLamp",
		Parent = dock,
		Size = Vector3.new(10, 8, 10),
		CFrame = CFrame.new(-55, 52, -20),
		Color = Config.Theme.Lantern,
		Material = Enum.Material.Neon,
		CanCollide = false,
	})
	local light = Instance.new("PointLight")
	light.Brightness = 4
	light.Range = 90
	light.Color = Config.Theme.Lantern
	light.Parent = lamp

	for i = 1, 8 do
		part({
			Name = "Crate" .. i,
			Parent = dock,
			Size = Vector3.new(5, 5, 5),
			CFrame = CFrame.new(-22 + i * 5, 6.5, -30 + (i % 3) * 5),
			Color = Color3.fromRGB(130, 90, 50),
			Material = Enum.Material.Wood,
		})
	end

	for i = 1, 6 do
		part({
			Name = "Buoy" .. i,
			Parent = dock,
			Size = Vector3.new(4, 7, 4),
			CFrame = CFrame.new(-70 + i * 26, 3, 55 + (i % 2) * 14),
			Color = if i % 2 == 0 then Color3.fromRGB(230, 55, 50) else Color3.fromRGB(245, 245, 245),
			Material = Enum.Material.SmoothPlastic,
			CanCollide = false,
		})
	end

	local title = part({
		Name = "TitleBanner",
		Parent = dock,
		Size = Vector3.new(2, 2, 2),
		CFrame = CFrame.new(0, 22, -35),
		Transparency = 1,
		CanCollide = false,
		CastShadow = false,
	})
	billboard(title, "SURVIVE AT SEA\nBOARDING DOCK", Config.Theme.Foam, UDim2.fromOffset(520, 140), 0)

	local portalsFolder = Instance.new("Folder")
	portalsFolder.Name = "Portals"
	portalsFolder.Parent = root

	local startX = -((Config.PortalCount - 1) * Config.PortalSpacing) / 2
	for i = 1, Config.PortalCount do
		local pos = Vector3.new(startX + (i - 1) * Config.PortalSpacing, 3.5, 70)
		buildPortal(portalsFolder, i, pos)
	end

	for z = 20, 55, 12 do
		part({
			Name = "Arrow",
			Parent = root,
			Size = Vector3.new(6, 0.5, 8),
			CFrame = CFrame.new(0, 4, z),
			Color = Config.Theme.PortalGlow,
			Material = Enum.Material.Neon,
			CanCollide = false,
		})
	end

	local staging = Instance.new("Folder")
	staging.Name = "VoyageStaging"
	staging.Parent = root
	part({
		Name = "Deck",
		Parent = staging,
		Size = Vector3.new(70, 3, 46),
		CFrame = CFrame.new(0, 2, 220),
		Color = Color3.fromRGB(90, 65, 40),
		Material = Enum.Material.WoodPlanks,
	})

	local spawn = Instance.new("SpawnLocation")
	spawn.Name = "LobbySpawn"
	spawn.Size = Vector3.new(14, 1, 14)
	spawn.CFrame = CFrame.new(0, 4.2, 0)
	spawn.Anchored = true
	spawn.Duration = 0
	spawn.Neutral = true
	spawn.Enabled = true
	spawn.Transparency = 0.3
	spawn.BrickColor = BrickColor.new("Cyan")
	spawn.Material = Enum.Material.Neon
	spawn.Parent = root

	print("[SurviveAtSea] LobbyWorld.ensure built dock + portals")
	return root
end

function LobbyWorld.seatCharacter(character: Model)
	local root = character:FindFirstChild("HumanoidRootPart")
	if root and root:IsA("BasePart") then
		root.CFrame = LobbyWorld.getLobbySpawnCFrame() * CFrame.Angles(0, 0, 0)
		-- Face portals (+Z)
		root.CFrame = CFrame.new(root.Position, root.Position + Vector3.new(0, 0, 40))
	end
end

return LobbyWorld
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="5">
        <Properties>
          <string name="Name">PartyCode</string>
          <string name="Source"><![CDATA[-- Generates short, shareable party codes (Dead Rails-style).

local HttpService = game:GetService("HttpService")

local PartyCode = {}

local ALPHABET = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"

local function randomChar(): string
	local index = math.random(1, #ALPHABET)
	return string.sub(ALPHABET, index, index)
end

function PartyCode.generate(existing: { [string]: any }?): string
	for _ = 1, 40 do
		local code = `{randomChar()}{randomChar()}{randomChar()}{randomChar()}`
		if not existing or existing[code] == nil then
			return code
		end
	end

	-- Extremely unlikely fallback
	return string.upper(string.sub(HttpService:GenerateGUID(false), 1, 4))
end

function PartyCode.normalize(raw: string): string
	local cleaned = string.upper(string.gsub(raw, "%s+", ""))
	cleaned = string.gsub(cleaned, "[^A-Z0-9]", "")
	return cleaned
end

return PartyCode
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="6">
        <Properties>
          <string name="Name">Remotes</string>
          <string name="Source"><![CDATA[-- RemoteEvent / RemoteFunction folder contract.
-- Server creates the folder; client waits for it.

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Remotes = {}

local FOLDER_NAME = "SurviveAtSeaRemotes"

function Remotes.getFolder(): Folder
	local folder = ReplicatedStorage:FindFirstChild(FOLDER_NAME)
	if folder and folder:IsA("Folder") then
		return folder
	end

	folder = ReplicatedStorage:WaitForChild(FOLDER_NAME, 30)
	assert(folder and folder:IsA("Folder"), "Survive at Sea remotes folder missing")
	return folder
end

function Remotes.waitFor(name: string): Instance
	local folder = Remotes.getFolder()
	local remote = folder:WaitForChild(name, 30)
	assert(remote, `Remote '{name}' missing`)
	return remote
end

function Remotes.createServerRemotes(): Folder
	local existing = ReplicatedStorage:FindFirstChild(FOLDER_NAME)
	if existing and existing:IsA("Folder") then
		return existing
	end

	local folder = Instance.new("Folder")
	folder.Name = FOLDER_NAME
	folder.Parent = ReplicatedStorage

	local names = {
		"CreateParty",
		"JoinParty",
		"LeaveParty",
		"StartLaunch",
		"PartyUpdated",
		"PortalsUpdated",
		"Toast",
		"GetLobbyState",
	}

	for _, name in names do
		local remote: Instance
		if name == "GetLobbyState" then
			remote = Instance.new("RemoteFunction")
		else
			remote = Instance.new("RemoteEvent")
		end
		remote.Name = name
		remote.Parent = folder
	end

	return folder
end

return Remotes
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="7">
        <Properties>
          <string name="Name">Types</string>
          <string name="Source"><![CDATA[-- Shared type aliases for Survive at Sea lobby / party flow.

export type PartyPrivacy = "Public" | "Private"

export type PartyMember = {
	userId: number,
	displayName: string,
	isHost: boolean,
}

export type PartySnapshot = {
	code: string,
	hostUserId: number,
	maxPlayers: number,
	privacy: PartyPrivacy,
	members: { PartyMember },
	portalIndex: number,
	countdownEndsAt: number?,
	status: "Open" | "Launching" | "Departed",
}

export type PublicPortalInfo = {
	portalIndex: number,
	code: string?,
	hostName: string?,
	memberCount: number,
	maxPlayers: number,
	status: "Empty" | "Open" | "Launching" | "Full",
}

return {}
]]></string>
        </Properties>
      </Item>
    </Item>
  </Item>
  <Item class="ServerScriptService" referent="8">
    <Properties>
      <string name="Name">ServerScriptService</string>
    </Properties>
    <Item class="Folder" referent="9">
      <Properties>
        <string name="Name">SurviveAtSea</string>
      </Properties>
      <Item class="Script" referent="10">
        <Properties>
          <string name="Name">Bootstrap</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Survive at Sea · Server bootstrap

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

print("[SurviveAtSea] Server bootstrap starting…")

local Shared = ReplicatedStorage:WaitForChild("Shared", 30)
if not Shared then
	error("[SurviveAtSea] ReplicatedStorage.Shared missing — is Rojo connected?")
end

local Config = require(Shared:WaitForChild("Config"))
local Remotes = require(Shared:WaitForChild("Remotes"))
local PartyCode = require(Shared:WaitForChild("PartyCode"))
local LobbyWorld = require(Shared:WaitForChild("LobbyWorld"))

local LobbyBuilder = require(script.Parent:WaitForChild("LobbyBuilder"))
local PartyService = require(script.Parent:WaitForChild("PartyService"))
local PortalService = require(script.Parent:WaitForChild("PortalService"))

print(`[SurviveAtSea] Booting {Config.GameName} lobby…`)

-- Build/replicate dock on the server so all players share it
local lobby = LobbyWorld.ensure()
LobbyBuilder.enhanceExisting(lobby)

local remoteFolder = Remotes.createServerRemotes()
local CreateParty = remoteFolder:WaitForChild("CreateParty")
local JoinParty = remoteFolder:WaitForChild("JoinParty")
local LeaveParty = remoteFolder:WaitForChild("LeaveParty")
local StartLaunch = remoteFolder:WaitForChild("StartLaunch")
local PartyUpdated = remoteFolder:WaitForChild("PartyUpdated")
local PortalsUpdated = remoteFolder:WaitForChild("PortalsUpdated")
local Toast = remoteFolder:WaitForChild("Toast")
local GetLobbyState = remoteFolder:WaitForChild("GetLobbyState")

PortalService.start(Toast, PartyUpdated, PortalsUpdated)

GetLobbyState.OnServerInvoke = function(player)
	return PartyService.getLobbyState(player)
end

CreateParty.OnServerEvent:Connect(function(player, portalIndex, maxPlayers, privacy)
	if typeof(portalIndex) ~= "number" or typeof(maxPlayers) ~= "number" then
		Toast:FireClient(player, "Invalid boarding request.", "error")
		return
	end
	local privacyValue = if privacy == "Private" then "Private" else "Public"
	local ok, message, snapshot = PartyService.createParty(player, portalIndex, maxPlayers, privacyValue)
	Toast:FireClient(player, message, if ok then "success" else "error")
	if ok and snapshot then
		PartyUpdated:FireClient(player, snapshot)
	end
end)

JoinParty.OnServerEvent:Connect(function(player, rawCode)
	if typeof(rawCode) ~= "string" then
		Toast:FireClient(player, "Enter a crew code.", "error")
		return
	end
	local ok, message, snapshot = PartyService.joinParty(player, PartyCode.normalize(rawCode))
	Toast:FireClient(player, message, if ok then "success" else "error")
	if ok and snapshot then
		PartyUpdated:FireClient(player, snapshot)
	end
end)

LeaveParty.OnServerEvent:Connect(function(player)
	local ok, message = PartyService.leaveParty(player)
	Toast:FireClient(player, message, if ok then "info" else "error")
	if ok then
		PartyUpdated:FireClient(player, nil)
	end
end)

StartLaunch.OnServerEvent:Connect(function(player)
	local ok, message, snapshot = PartyService.startLaunch(player)
	Toast:FireClient(player, message, if ok then "success" else "error")
	if ok and snapshot then
		PartyUpdated:FireClient(player, snapshot)
	end
end)

local function onPlayerReady(player)
	player.CharacterAdded:Connect(function(character)
		task.defer(function()
			LobbyWorld.seatCharacter(character)
		end)
	end)
	if player.Character then
		task.defer(function()
			LobbyWorld.seatCharacter(player.Character :: Model)
		end)
	end

	task.defer(function()
		PortalsUpdated:FireClient(player, PartyService.getPortalInfos())
		Toast:FireClient(player, "Walk forward to the glowing portals!", "info")
	end)
end

Players.PlayerRemoving:Connect(function(player)
	PartyService.onPlayerRemoving(player)
end)

for _, player in Players:GetPlayers() do
	onPlayerReady(player)
end
Players.PlayerAdded:Connect(onPlayerReady)

print(`[SurviveAtSea] Lobby ready — max crew {Config.MaxPartySize}, no session saves.`)
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="11">
        <Properties>
          <string name="Name">LobbyBuilder</string>
          <string name="Source"><![CDATA[-- Builds the Survive at Sea lobby: dock, ocean, boarding portals.
-- Geometry is created at runtime so the template stays Rojo-friendly.

local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local Config = require(Shared:WaitForChild("Config"))

local LobbyBuilder = {}

local function part(props: { [string]: any }): Part
	local p = Instance.new("Part")
	p.Anchored = true
	p.CanCollide = if props.CanCollide == nil then true else props.CanCollide
	p.Material = props.Material or Enum.Material.Wood
	p.Color = props.Color or Config.Theme.Driftwood
	p.Size = props.Size or Vector3.new(4, 1, 4)
	p.CFrame = props.CFrame or CFrame.new()
	p.Name = props.Name or "LobbyPart"
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.CastShadow = if props.CastShadow == nil then true else props.CastShadow
	if props.Transparency ~= nil then
		p.Transparency = props.Transparency
	end
	if props.Reflectance ~= nil then
		p.Reflectance = props.Reflectance
	end
	if props.Parent then
		p.Parent = props.Parent
	end
	return p
end

local function billboard(adornee: BasePart, text: string, color: Color3, size: UDim2?, offsetY: number?): BillboardGui
	local gui = Instance.new("BillboardGui")
	gui.Name = "LobbyBillboard"
	gui.Adornee = adornee
	gui.Size = size or UDim2.fromOffset(280, 90)
	gui.StudsOffsetWorldSpace = Vector3.new(0, offsetY or 8, 0)
	gui.AlwaysOnTop = true
	gui.MaxDistance = 250
	gui.Parent = adornee

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 0.15
	label.BackgroundColor3 = Config.Theme.UIPanel
	label.BorderSizePixel = 0
	label.Size = UDim2.fromScale(1, 1)
	label.Font = Enum.Font.GothamBlack
	label.TextScaled = true
	label.TextColor3 = color
	label.Text = text
	label.Parent = gui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = label

	local pad = Instance.new("UIPadding")
	pad.PaddingTop = UDim.new(0, 8)
	pad.PaddingBottom = UDim.new(0, 8)
	pad.PaddingLeft = UDim.new(0, 12)
	pad.PaddingRight = UDim.new(0, 12)
	pad.Parent = label

	local stroke = Instance.new("UIStroke")
	stroke.Color = Config.Theme.UIAccent
	stroke.Thickness = 2
	stroke.Parent = label

	return gui
end

local function safeLighting()
	-- Never let lighting tweaks prevent the dock from spawning.
	local ok, err = pcall(function()
		Lighting.ClockTime = 16.5
		Lighting.Brightness = 3
		Lighting.Ambient = Color3.fromRGB(50, 90, 110)
		Lighting.OutdoorAmbient = Color3.fromRGB(90, 140, 160)
		Lighting.FogColor = Color3.fromRGB(70, 140, 170)
		Lighting.FogStart = 200
		Lighting.FogEnd = 800
		Lighting.GlobalShadows = true

		for _, child in Lighting:GetChildren() do
			if child:IsA("Atmosphere") or child:IsA("BloomEffect") or child:IsA("ColorCorrectionEffect") then
				child:Destroy()
			end
		end

		local atmosphere = Instance.new("Atmosphere")
		atmosphere.Density = 0.18
		atmosphere.Offset = 0.1
		atmosphere.Color = Color3.fromRGB(140, 185, 205)
		atmosphere.Decay = Color3.fromRGB(50, 90, 120)
		atmosphere.Glare = 0.08
		atmosphere.Haze = 0.6
		atmosphere.Parent = Lighting

		local sky = Lighting:FindFirstChildOfClass("Sky")
		if not sky then
			sky = Instance.new("Sky")
			sky.Parent = Lighting
		end
		sky.CelestialBodiesShown = true
		sky.StarCount = 1200
		sky.SunAngularSize = 21
		sky.MoonAngularSize = 11

		local bloom = Instance.new("BloomEffect")
		bloom.Intensity = 0.25
		bloom.Size = 14
		bloom.Threshold = 1.2
		bloom.Parent = Lighting

		local cc = Instance.new("ColorCorrectionEffect")
		cc.TintColor = Color3.fromRGB(225, 242, 255)
		cc.Contrast = 0.05
		cc.Saturation = 0.15
		cc.Parent = Lighting
	end)
	if not ok then
		warn("[SurviveAtSea] Lighting setup failed (lobby still builds):", err)
	end
end

local function clearWorkspaceClutter()
	-- Remove default / leftover place geometry so the dock is obvious.
	for _, name in { "Baseplate", "SpawnLocation", "Terrain" } do
		local inst = Workspace:FindFirstChild(name)
		if inst and not inst:IsA("Terrain") then
			inst:Destroy()
		end
	end

	-- Clear common starter-place leftovers (keeps cameras/characters)
	for _, child in Workspace:GetChildren() do
		if child:IsA("BasePart") or child:IsA("Model") or child:IsA("Folder") then
			if child.Name ~= "SurviveAtSeaLobby" and child.Name ~= "Camera" and child.Name ~= "Terrain" then
				-- Keep player characters
				local isCharacter = false
				for _, plr in Players:GetPlayers() do
					if plr.Character == child then
						isCharacter = true
						break
					end
				end
				if not isCharacter then
					child:Destroy()
				end
			end
		end
	end
end

local function buildOcean(folder: Folder)
	-- Solid water plane players can stand near / see clearly
	part({
		Name = "OceanDeep",
		Parent = folder,
		Size = Vector3.new(1200, 30, 1200),
		CFrame = CFrame.new(0, -16, 0),
		Color = Color3.fromRGB(6, 40, 70),
		Material = Enum.Material.SmoothPlastic,
		Transparency = 0.15,
		CanCollide = true,
	})

	part({
		Name = "OceanSurface",
		Parent = folder,
		Size = Vector3.new(1200, 2, 1200),
		CFrame = CFrame.new(0, 0, 0),
		Color = Color3.fromRGB(20, 120, 150),
		Material = Enum.Material.Glass,
		Transparency = 0.45,
		Reflectance = 0.15,
		CanCollide = false,
	})

	-- Shore foam ring around dock
	part({
		Name = "Foam",
		Parent = folder,
		Size = Vector3.new(160, 0.6, 160),
		CFrame = CFrame.new(0, 1.2, 20),
		Color = Config.Theme.Foam,
		Material = Enum.Material.SmoothPlastic,
		Transparency = 0.55,
		CanCollide = false,
	})
end

local function buildDock(folder: Folder)
	local dock = Instance.new("Folder")
	dock.Name = "Dock"
	dock.Parent = folder

	-- Huge visible pier under spawn
	part({
		Name = "PierDeck",
		Parent = dock,
		Size = Vector3.new(80, 3, 140),
		CFrame = CFrame.new(0, 2, 20),
		Color = Color3.fromRGB(120, 82, 48),
		Material = Enum.Material.WoodPlanks,
	})

	-- Bright center stripe so you know you landed
	part({
		Name = "CenterPlank",
		Parent = dock,
		Size = Vector3.new(8, 3.2, 140),
		CFrame = CFrame.new(0, 2, 20),
		Color = Color3.fromRGB(170, 120, 70),
		Material = Enum.Material.WoodPlanks,
	})

	-- Rails
	for _, x in { -38, 38 } do
		part({
			Name = "Rail",
			Parent = dock,
			Size = Vector3.new(1.5, 4, 140),
			CFrame = CFrame.new(x, 5, 20),
			Color = Color3.fromRGB(90, 60, 35),
			Material = Enum.Material.Wood,
		})
	end

	-- Pillars into the water
	for z = -40, 80, 20 do
		for _, x in { -30, 30 } do
			part({
				Name = "Pillar",
				Parent = dock,
				Size = Vector3.new(4, 18, 4),
				CFrame = CFrame.new(x, -5, z),
				Color = Color3.fromRGB(70, 48, 28),
				Material = Enum.Material.Wood,
			})
		end
	end

	-- Lighthouse (very visible landmark)
	local tower = part({
		Name = "Lighthouse",
		Parent = dock,
		Size = Vector3.new(12, 48, 12),
		CFrame = CFrame.new(-55, 25, -20),
		Color = Color3.fromRGB(240, 240, 235),
		Material = Enum.Material.SmoothPlastic,
	})
	part({
		Name = "LighthouseStripe",
		Parent = dock,
		Size = Vector3.new(12.4, 8, 12.4),
		CFrame = CFrame.new(-55, 18, -20),
		Color = Color3.fromRGB(200, 60, 55),
		Material = Enum.Material.SmoothPlastic,
	})
	local lamp = part({
		Name = "LighthouseLamp",
		Parent = dock,
		Size = Vector3.new(10, 8, 10),
		CFrame = CFrame.new(-55, 52, -20),
		Color = Config.Theme.Lantern,
		Material = Enum.Material.Neon,
		CanCollide = false,
	})
	local light = Instance.new("PointLight")
	light.Brightness = 4
	light.Range = 90
	light.Color = Config.Theme.Lantern
	light.Parent = lamp

	-- Crates
	for i = 1, 8 do
		part({
			Name = "Crate" .. i,
			Parent = dock,
			Size = Vector3.new(5, 5, 5),
			CFrame = CFrame.new(-22 + i * 5, 6.5, -30 + (i % 3) * 5) * CFrame.Angles(0, math.rad(i * 12), 0),
			Color = Color3.fromRGB(130, 90, 50),
			Material = Enum.Material.Wood,
		})
	end

	-- Bobbing buoys
	for i = 1, 6 do
		local buoy = part({
			Name = "Buoy" .. i,
			Parent = dock,
			Size = Vector3.new(4, 7, 4),
			CFrame = CFrame.new(-70 + i * 26, 3, 55 + (i % 2) * 14),
			Color = if i % 2 == 0 then Color3.fromRGB(230, 55, 50) else Color3.fromRGB(245, 245, 245),
			Material = Enum.Material.SmoothPlastic,
			CanCollide = false,
		})
		task.spawn(function()
			local t = i * 1.7
			while buoy.Parent do
				t += 0.05
				local pos = buoy.Position
				buoy.CFrame = CFrame.new(pos.X, 3 + math.sin(t) * 0.8, pos.Z)
					* CFrame.Angles(0, t * 0.25, math.rad(math.sin(t) * 8))
				task.wait(0.05)
			end
		end)
	end

	-- Title banner above dock
	local titleAnchor = part({
		Name = "TitleAnchor",
		Parent = dock,
		Size = Vector3.new(2, 2, 2),
		CFrame = CFrame.new(0, 22, -35),
		Transparency = 1,
		CanCollide = false,
		CastShadow = false,
	})
	billboard(titleAnchor, "SURVIVE AT SEA\nBOARDING DOCK", Config.Theme.Foam, UDim2.fromOffset(520, 140), 0)

	return tower
end

local function buildPortal(folder: Folder, index: number, position: Vector3): Model
	local model = Instance.new("Model")
	model.Name = "Portal_" .. index
	model.Parent = folder

	local pad = part({
		Name = "Pad",
		Parent = model,
		Size = Vector3.new(18, 1.5, 18),
		CFrame = CFrame.new(position),
		Color = Color3.fromRGB(80, 58, 36),
		Material = Enum.Material.WoodPlanks,
	})

	-- Neon ring so portals pop from spawn
	part({
		Name = "NeonRing",
		Parent = model,
		Size = Vector3.new(18.5, 0.6, 18.5),
		CFrame = CFrame.new(position + Vector3.new(0, 0.9, 0)),
		Color = Config.Theme.PortalGlow,
		Material = Enum.Material.Neon,
		CanCollide = false,
	})

	for _, offsetX in { -7, 7 } do
		part({
			Name = "ArchLeg",
			Parent = model,
			Size = Vector3.new(2.5, 18, 2.5),
			CFrame = CFrame.new(position + Vector3.new(offsetX, 10, 0)),
			Color = Color3.fromRGB(95, 65, 40),
			Material = Enum.Material.Wood,
		})
	end

	part({
		Name = "ArchTop",
		Parent = model,
		Size = Vector3.new(18, 2.5, 2.5),
		CFrame = CFrame.new(position + Vector3.new(0, 20, 0)),
		Color = Color3.fromRGB(95, 65, 40),
		Material = Enum.Material.Wood,
	})

	local gate = part({
		Name = "Gate",
		Parent = model,
		Size = Vector3.new(11, 15, 1.4),
		CFrame = CFrame.new(position + Vector3.new(0, 9, 0)),
		Color = Config.Theme.PortalGlow,
		Material = Enum.Material.ForceField,
		Transparency = 0.25,
		CanCollide = false,
	})

	local gateLight = Instance.new("PointLight")
	gateLight.Color = Config.Theme.PortalGlow
	gateLight.Brightness = 3
	gateLight.Range = 28
	gateLight.Parent = gate

	task.spawn(function()
		local info = TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
		TweenService:Create(gate, info, { Transparency = 0.55 }):Play()
	end)

	local promptPart = part({
		Name = "PromptAnchor",
		Parent = model,
		Size = Vector3.new(6, 6, 6),
		CFrame = CFrame.new(position + Vector3.new(0, 3, 6)),
		Transparency = 1,
		CanCollide = false,
		CastShadow = false,
	})

	local prompt = Instance.new("ProximityPrompt")
	prompt.Name = "BoardPrompt"
	prompt.ObjectText = "Voyage Portal " .. index
	prompt.ActionText = "Create Crew"
	prompt.HoldDuration = 0.25
	prompt.MaxActivationDistance = 16
	prompt.RequiresLineOfSight = false
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.Style = Enum.ProximityPromptStyle.Default
	prompt.Parent = promptPart

	local indexValue = Instance.new("IntValue")
	indexValue.Name = "PortalIndex"
	indexValue.Value = index
	indexValue.Parent = model

	billboard(pad, `PORTAL {index}\nWalk up · press E`, Config.Theme.Foam, UDim2.fromOffset(240, 80), 10)

	model.PrimaryPart = pad
	return model
end

local function buildVoyageStaging(folder: Folder)
	local staging = Instance.new("Folder")
	staging.Name = "VoyageStaging"
	staging.Parent = folder

	part({
		Name = "Deck",
		Parent = staging,
		Size = Vector3.new(70, 3, 46),
		CFrame = CFrame.new(0, 2, 220),
		Color = Color3.fromRGB(90, 65, 40),
		Material = Enum.Material.WoodPlanks,
	})

	part({
		Name = "Hull",
		Parent = staging,
		Size = Vector3.new(56, 12, 8),
		CFrame = CFrame.new(0, 7, 240),
		Color = Color3.fromRGB(60, 42, 28),
		Material = Enum.Material.Wood,
	})

	local sign = part({
		Name = "VoyageSign",
		Parent = staging,
		Size = Vector3.new(1, 1, 1),
		CFrame = CFrame.new(0, 16, 220),
		Transparency = 1,
		CanCollide = false,
	})
	billboard(sign, "VOYAGE UNDERWAY\n(No save — session only)", Config.Theme.Lantern, UDim2.fromOffset(400, 100), 0)
end

local function setupSpawn(folder: Folder)
	local spawn = Instance.new("SpawnLocation")
	spawn.Name = "LobbySpawn"
	spawn.Size = Vector3.new(14, 1, 14)
	spawn.CFrame = CFrame.new(0, 4.2, 0)
	spawn.Anchored = true
	spawn.Duration = 0
	spawn.Neutral = true
	spawn.Enabled = true
	spawn.Transparency = 0.3
	spawn.BrickColor = BrickColor.new("Cyan")
	spawn.Material = Enum.Material.Neon
	spawn.Parent = folder

	-- Face the portals (positive Z)
	spawn.CFrame = CFrame.new(0, 4.2, 0) * CFrame.Angles(0, 0, 0)
end

function LobbyBuilder.enhanceExisting(root: Folder)
	safeLighting()

	local spawn = root:FindFirstChild("LobbySpawn")
	if not (spawn and spawn:IsA("SpawnLocation")) then
		setupSpawn(root)
	else
		local spawnLocation = spawn :: SpawnLocation
		spawnLocation.Enabled = true
		spawnLocation.Neutral = true
	end

	-- World-space title
	local dock = root:FindFirstChild("Dock")
	if dock and not dock:FindFirstChild("TitleBanner") then
		local titleAnchor = part({
			Name = "TitleBanner",
			Parent = dock,
			Size = Vector3.new(2, 2, 2),
			CFrame = CFrame.new(0, 22, -35),
			Transparency = 1,
			CanCollide = false,
			CastShadow = false,
		})
		billboard(titleAnchor, "SURVIVE AT SEA\nBOARDING DOCK", Config.Theme.Foam, UDim2.fromOffset(520, 140), 0)
	end

	local portals = root:FindFirstChild("Portals")
	if portals then
		for _, model in portals:GetChildren() do
			if not model:IsA("Model") then
				continue
			end
			local pad = model:FindFirstChild("Pad")
			local indexValue = model:FindFirstChild("PortalIndex")
			local index = if indexValue and indexValue:IsA("IntValue") then indexValue.Value else 0
			if pad and pad:IsA("BasePart") and not pad:FindFirstChild("LobbyBillboard") then
				billboard(pad, `PORTAL {index}\nWalk up · press E`, Config.Theme.Foam, UDim2.fromOffset(260, 90), 10)
			end

			local gate = model:FindFirstChild("Gate")
			if gate and gate:IsA("BasePart") then
				if not gate:FindFirstChildOfClass("PointLight") then
					local light = Instance.new("PointLight")
					light.Color = Config.Theme.PortalGlow
					light.Brightness = 3
					light.Range = 28
					light.Parent = gate
				end
				task.spawn(function()
					local info = TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
					TweenService:Create(gate, info, { Transparency = 0.55 }):Play()
				end)
			end
		end
	end

	print("[SurviveAtSea] Enhanced existing lobby map")
end

function LobbyBuilder.build(): Folder
	local existing = Workspace:FindFirstChild("SurviveAtSeaLobby")
	if existing then
		existing:Destroy()
	end

	clearWorkspaceClutter()
	safeLighting()

	local root = Instance.new("Folder")
	root.Name = "SurviveAtSeaLobby"
	root.Parent = Workspace

	buildOcean(root)
	buildDock(root)
	buildVoyageStaging(root)
	setupSpawn(root)

	local portalsFolder = Instance.new("Folder")
	portalsFolder.Name = "Portals"
	portalsFolder.Parent = root

	local startX = -((Config.PortalCount - 1) * Config.PortalSpacing) / 2
	for i = 1, Config.PortalCount do
		local pos = Vector3.new(startX + (i - 1) * Config.PortalSpacing, 3.5, 70)
		buildPortal(portalsFolder, i, pos)
	end

	for z = 20, 55, 12 do
		part({
			Name = "Arrow",
			Parent = root,
			Size = Vector3.new(6, 0.5, 8),
			CFrame = CFrame.new(0, 4, z),
			Color = Config.Theme.PortalGlow,
			Material = Enum.Material.Neon,
			CanCollide = false,
		})
	end

	print("[SurviveAtSea] Lobby geometry built — dock +", Config.PortalCount, "portals")
	return root
end

function LobbyBuilder.updatePortalSign(portalModel: Model, title: string, subtitle: string, color: Color3?)
	local pad = portalModel:FindFirstChild("Pad")
	if not (pad and pad:IsA("BasePart")) then
		return
	end
	local old = pad:FindFirstChild("LobbyBillboard")
	if old then
		old:Destroy()
	end
	billboard(pad, `{title}\n{subtitle}`, color or Config.Theme.Foam, UDim2.fromOffset(260, 90), 10)
end

function LobbyBuilder.getPortalModel(index: number): Model?
	local root = Workspace:FindFirstChild("SurviveAtSeaLobby")
	if not root then
		return nil
	end
	local portals = root:FindFirstChild("Portals")
	if not portals then
		return nil
	end
	local model = portals:FindFirstChild("Portal_" .. index)
	if model and model:IsA("Model") then
		return model
	end
	return nil
end

function LobbyBuilder.getVoyageSpawnCFrame(): CFrame
	return CFrame.new(0, 6, 220)
end

function LobbyBuilder.getLobbySpawnCFrame(): CFrame
	return CFrame.new(0, 6, 0)
end

function LobbyBuilder.teleportPlayerToLobby(player: Player)
	local character = player.Character
	if not character then
		return
	end
	local Shared = ReplicatedStorage:WaitForChild("Shared")
	local LobbyWorld = require(Shared:WaitForChild("LobbyWorld"))
	LobbyWorld.seatCharacter(character)
end

return LobbyBuilder
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="12">
        <Properties>
          <string name="Name">PartyService</string>
          <string name="Source"><![CDATA[-- Ephemeral party / game-state service.
-- No DataStore or MemoryStore caching — parties live only while this lobby server does.

local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")

local Shared = game:GetService("ReplicatedStorage"):WaitForChild("Shared")
local Config = require(Shared:WaitForChild("Config"))
local PartyCode = require(Shared:WaitForChild("PartyCode"))
local Types = require(Shared:WaitForChild("Types"))

type PartyPrivacy = Types.PartyPrivacy
type PartySnapshot = Types.PartySnapshot
type PartyMember = Types.PartyMember
type PublicPortalInfo = Types.PublicPortalInfo

export type PartyRecord = {
	code: string,
	hostUserId: number,
	maxPlayers: number,
	privacy: PartyPrivacy,
	portalIndex: number,
	memberUserIds: { number },
	countdownEndsAt: number?,
	status: "Open" | "Launching" | "Departed",
	reservedCode: string?,
}

local PartyService = {}
PartyService._partiesByCode = {} :: { [string]: PartyRecord }
PartyService._playerToCode = {} :: { [number]: string }
PartyService._portalToCode = {} :: { [number]: string }
PartyService._onChanged = nil :: ((PartySnapshot?, { PublicPortalInfo }) -> ())?

local function displayNameFor(userId: number): string
	local player = Players:GetPlayerByUserId(userId)
	if player then
		return player.DisplayName
	end
	return `Crew_{userId}`
end

local function toSnapshot(party: PartyRecord): PartySnapshot
	local members: { PartyMember } = {}
	for _, userId in party.memberUserIds do
		table.insert(members, {
			userId = userId,
			displayName = displayNameFor(userId),
			isHost = userId == party.hostUserId,
		})
	end

	return {
		code = party.code,
		hostUserId = party.hostUserId,
		maxPlayers = party.maxPlayers,
		privacy = party.privacy,
		members = members,
		portalIndex = party.portalIndex,
		countdownEndsAt = party.countdownEndsAt,
		status = party.status,
	}
end

local function buildPortalInfos(): { PublicPortalInfo }
	local infos = {}
	for i = 1, Config.PortalCount do
		local code = PartyService._portalToCode[i]
		local party = if code then PartyService._partiesByCode[code] else nil
		if not party then
			table.insert(infos, {
				portalIndex = i,
				code = nil,
				hostName = nil,
				memberCount = 0,
				maxPlayers = Config.MaxPartySize,
				status = "Empty",
			})
		else
			local status: "Empty" | "Open" | "Launching" | "Full" = "Open"
			if party.status == "Launching" or party.status == "Departed" then
				status = "Launching"
			elseif #party.memberUserIds >= party.maxPlayers then
				status = "Full"
			end
			table.insert(infos, {
				portalIndex = i,
				code = if party.privacy == "Public" then party.code else nil,
				hostName = displayNameFor(party.hostUserId),
				memberCount = #party.memberUserIds,
				maxPlayers = party.maxPlayers,
				status = status,
			})
		end
	end
	return infos
end

local function notify(party: PartyRecord?)
	if PartyService._onChanged then
		PartyService._onChanged(if party then toSnapshot(party) else nil, buildPortalInfos())
	end
end

local function removePlayerFromCurrentParty(userId: number)
	local code = PartyService._playerToCode[userId]
	if not code then
		return
	end

	local party = PartyService._partiesByCode[code]
	PartyService._playerToCode[userId] = nil
	if not party then
		return
	end

	local remaining = {}
	for _, id in party.memberUserIds do
		if id ~= userId then
			table.insert(remaining, id)
		end
	end
	party.memberUserIds = remaining

	if #remaining == 0 then
		PartyService._partiesByCode[code] = nil
		PartyService._portalToCode[party.portalIndex] = nil
		notify(nil)
		return
	end

	if party.hostUserId == userId then
		party.hostUserId = remaining[1]
	end

	notify(party)
end

function PartyService.setChangedCallback(callback: (PartySnapshot?, { PublicPortalInfo }) -> ())
	PartyService._onChanged = callback
end

function PartyService.getSnapshotForPlayer(player: Player): PartySnapshot?
	local code = PartyService._playerToCode[player.UserId]
	if not code then
		return nil
	end
	local party = PartyService._partiesByCode[code]
	if not party then
		return nil
	end
	return toSnapshot(party)
end

function PartyService.getPortalInfos(): { PublicPortalInfo }
	return buildPortalInfos()
end

function PartyService.getLobbyState(player: Player): { party: PartySnapshot?, portals: { PublicPortalInfo } }
	return {
		party = PartyService.getSnapshotForPlayer(player),
		portals = buildPortalInfos(),
	}
end

function PartyService.createParty(
	player: Player,
	portalIndex: number,
	maxPlayers: number,
	privacy: PartyPrivacy
): (boolean, string, PartySnapshot?)
	if PartyService._playerToCode[player.UserId] then
		return false, "Leave your current crew before creating another.", nil
	end

	if portalIndex < 1 or portalIndex > Config.PortalCount then
		return false, "That boarding portal doesn't exist.", nil
	end

	if PartyService._portalToCode[portalIndex] then
		return false, "That portal already has a crew boarding.", nil
	end

	maxPlayers = math.clamp(math.floor(maxPlayers), Config.MinPartySize, Config.MaxPartySize)
	if privacy ~= "Public" and privacy ~= "Private" then
		privacy = "Public"
	end

	local code = PartyCode.generate(PartyService._partiesByCode)
	local party: PartyRecord = {
		code = code,
		hostUserId = player.UserId,
		maxPlayers = maxPlayers,
		privacy = privacy,
		portalIndex = portalIndex,
		memberUserIds = { player.UserId },
		countdownEndsAt = nil,
		status = "Open",
		reservedCode = nil,
	}

	PartyService._partiesByCode[code] = party
	PartyService._playerToCode[player.UserId] = code
	PartyService._portalToCode[portalIndex] = code

	local snapshot = toSnapshot(party)
	notify(party)
	return true, "Crew assembled. Share your code with friends!", snapshot
end

function PartyService.joinParty(player: Player, rawCode: string): (boolean, string, PartySnapshot?)
	if PartyService._playerToCode[player.UserId] then
		return false, "You're already on a crew.", nil
	end

	local code = PartyCode.normalize(rawCode)
	if #code < 4 then
		return false, "Enter a valid crew code.", nil
	end

	local party = PartyService._partiesByCode[code]
	if not party then
		return false, "No crew found with that code.", nil
	end

	if party.status ~= "Open" then
		return false, "That voyage is already launching.", nil
	end

	if #party.memberUserIds >= party.maxPlayers then
		return false, "That crew is full (max 10).", nil
	end

	table.insert(party.memberUserIds, player.UserId)
	PartyService._playerToCode[player.UserId] = code

	local snapshot = toSnapshot(party)
	notify(party)
	return true, "You joined the crew!", snapshot
end

function PartyService.joinPortal(player: Player, portalIndex: number): (boolean, string, PartySnapshot?)
	local code = PartyService._portalToCode[portalIndex]
	if not code then
		return false, "Empty", nil
	end

	local party = PartyService._partiesByCode[code]
	if not party then
		return false, "Empty", nil
	end

	if party.privacy == "Private" then
		return false, "Private crew — ask the host for their code.", nil
	end

	return PartyService.joinParty(player, code)
end

function PartyService.leaveParty(player: Player): (boolean, string)
	if not PartyService._playerToCode[player.UserId] then
		return false, "You're not on a crew."
	end
	removePlayerFromCurrentParty(player.UserId)
	return true, "Left the crew."
end

function PartyService.startLaunch(player: Player): (boolean, string, PartySnapshot?)
	local code = PartyService._playerToCode[player.UserId]
	if not code then
		return false, "Create or join a crew first.", nil
	end

	local party = PartyService._partiesByCode[code]
	if not party then
		return false, "Crew not found.", nil
	end

	if party.hostUserId ~= player.UserId then
		return false, "Only the host can cast off.", nil
	end

	if party.status ~= "Open" then
		return false, "Launch already in progress.", nil
	end

	if #party.memberUserIds < 1 then
		return false, "Need at least one sailor.", nil
	end

	party.status = "Launching"
	-- Use server time so clients can render a synced countdown.
	party.countdownEndsAt = Workspace:GetServerTimeNow() + Config.LaunchCountdownSeconds
	notify(party)

	task.delay(Config.LaunchCountdownSeconds, function()
		PartyService._finalizeLaunch(party.code)
	end)

	return true, "Casting off!", toSnapshot(party)
end

function PartyService._finalizeLaunch(code: string)
	local party = PartyService._partiesByCode[code]
	if not party or party.status ~= "Launching" then
		return
	end

	party.status = "Departed"
	notify(party)

	local playersToTeleport: { Player } = {}
	for _, userId in party.memberUserIds do
		local plr = Players:GetPlayerByUserId(userId)
		if plr then
			table.insert(playersToTeleport, plr)
		end
	end

	if #playersToTeleport == 0 then
		PartyService._partiesByCode[code] = nil
		PartyService._portalToCode[party.portalIndex] = nil
		notify(nil)
		return
	end

	-- Prefer reserved-server teleport when a voyage place is configured.
	if typeof(Config.GamePlaceId) == "number" and Config.GamePlaceId > 0 then
		local ok, reservedCode = pcall(function()
			return TeleportService:ReserveServer(Config.GamePlaceId :: number)
		end)
		if ok and typeof(reservedCode) == "string" then
			party.reservedCode = reservedCode
			local teleportOk, err = pcall(function()
				TeleportService:TeleportToPrivateServer(
					Config.GamePlaceId :: number,
					reservedCode,
					playersToTeleport
				)
			end)
			if not teleportOk then
				warn("[SurviveAtSea] Teleport failed:", err)
			end
		else
			warn("[SurviveAtSea] ReserveServer failed; falling back to staging zone.")
			PartyService._sendToStaging(playersToTeleport)
		end
	else
		PartyService._sendToStaging(playersToTeleport)
	end

	-- Clear ephemeral party after launch (no save / no rejoin cache)
	for _, userId in party.memberUserIds do
		PartyService._playerToCode[userId] = nil
	end
	PartyService._partiesByCode[code] = nil
	PartyService._portalToCode[party.portalIndex] = nil
	notify(nil)
end

function PartyService._sendToStaging(playersToTeleport: { Player })
	local LobbyBuilder = require(script.Parent.LobbyBuilder)
	local destination = LobbyBuilder.getVoyageSpawnCFrame()

	for index, player in playersToTeleport do
		local character = player.Character
		local root = character and character:FindFirstChild("HumanoidRootPart")
		if root and root:IsA("BasePart") then
			local offset = Vector3.new(((index - 1) % 5) * 4 - 8, 0, math.floor((index - 1) / 5) * 4)
			root.CFrame = destination + offset
		end
	end
end

function PartyService.onPlayerRemoving(player: Player)
	removePlayerFromCurrentParty(player.UserId)
end

return PartyService
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="13">
        <Properties>
          <string name="Name">PortalService</string>
          <string name="Source"><![CDATA[-- Wires portal proximity prompts and keeps world signs in sync with parties.

local Shared = game:GetService("ReplicatedStorage"):WaitForChild("Shared")
local Config = require(Shared:WaitForChild("Config"))

local LobbyBuilder = require(script.Parent.LobbyBuilder)
local PartyService = require(script.Parent.PartyService)

local PortalService = {}

local function refreshPortalVisuals(portals)
	for _, info in portals do
		local model = LobbyBuilder.getPortalModel(info.portalIndex)
		if not model then
			continue
		end

		local promptAnchor = model:FindFirstChild("PromptAnchor")
		local prompt = promptAnchor and promptAnchor:FindFirstChild("BoardPrompt")

		if info.status == "Empty" then
			LobbyBuilder.updatePortalSign(model, `PORTAL {info.portalIndex}`, "Empty berth — create a crew", Config.Theme.Foam)
			if prompt and prompt:IsA("ProximityPrompt") then
				prompt.ActionText = "Create Crew"
				prompt.ObjectText = `Voyage Portal {info.portalIndex}`
				prompt.Enabled = true
			end
		elseif info.status == "Launching" then
			LobbyBuilder.updatePortalSign(
				model,
				`PORTAL {info.portalIndex}`,
				`Casting off — {info.memberCount}/{info.maxPlayers}`,
				Config.Theme.Lantern
			)
			if prompt and prompt:IsA("ProximityPrompt") then
				prompt.Enabled = false
			end
		elseif info.status == "Full" then
			LobbyBuilder.updatePortalSign(
				model,
				`PORTAL {info.portalIndex}`,
				`Full crew · {info.hostName}`,
				Config.Theme.DangerRed
			)
			if prompt and prompt:IsA("ProximityPrompt") then
				prompt.ActionText = "Crew Full"
				prompt.Enabled = false
			end
		else
			local codeLine = if info.code then `Code {info.code}` else "Private berth"
			LobbyBuilder.updatePortalSign(
				model,
				`PORTAL {info.portalIndex}`,
				`{info.hostName} · {info.memberCount}/{info.maxPlayers}\n{codeLine}`,
				Config.Theme.UIAccent
			)
			if prompt and prompt:IsA("ProximityPrompt") then
				prompt.ActionText = if info.code then "Join Public Crew" else "Private — use code"
				prompt.ObjectText = `Voyage Portal {info.portalIndex}`
				prompt.Enabled = info.code ~= nil
			end
		end
	end
end

function PortalService.start(toastRemote: RemoteEvent, partyUpdated: RemoteEvent, portalsUpdated: RemoteEvent)
	PartyService.setChangedCallback(function(partySnapshot, portalInfos)
		refreshPortalVisuals(portalInfos)
		portalsUpdated:FireAllClients(portalInfos)
		if partySnapshot then
			for _, member in partySnapshot.members do
				local player = game:GetService("Players"):GetPlayerByUserId(member.userId)
				if player then
					partyUpdated:FireClient(player, partySnapshot)
				end
			end
		end
	end)

	-- Initial paint
	refreshPortalVisuals(PartyService.getPortalInfos())

	local root = game:GetService("Workspace"):WaitForChild("SurviveAtSeaLobby")
	local portalsFolder = root:WaitForChild("Portals")

	for _, model in portalsFolder:GetChildren() do
		if not model:IsA("Model") then
			continue
		end
		local indexValue = model:FindFirstChild("PortalIndex")
		local promptAnchor = model:FindFirstChild("PromptAnchor")
		local prompt = promptAnchor and promptAnchor:FindFirstChild("BoardPrompt")
		if not (indexValue and indexValue:IsA("IntValue") and prompt and prompt:IsA("ProximityPrompt")) then
			continue
		end

		local portalIndex = indexValue.Value
		prompt.Triggered:Connect(function(player: Player)
			local infos = PartyService.getPortalInfos()
			local info = infos[portalIndex]
			if not info or info.status == "Empty" then
				-- Client opens create UI; server just acknowledges empty portal.
				toastRemote:FireClient(player, "Pick crew size and cast your berth.", "info")
				partyUpdated:FireClient(player, {
					__openCreate = true,
					portalIndex = portalIndex,
				})
				return
			end

			local ok, message, snapshot = PartyService.joinPortal(player, portalIndex)
			toastRemote:FireClient(player, message, if ok then "success" else "error")
			if ok and snapshot then
				partyUpdated:FireClient(player, snapshot)
			end
		end)
	end
end

return PortalService
]]></string>
        </Properties>
