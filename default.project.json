{
  "name": "SurviveAtSea",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      }
    },

    "ServerScriptService": {
      "SurviveAtSea": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      },
      "$properties": {
        "CameraMaxZoomDistance": 120,
        "CameraMinZoomDistance": 0.5
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true,
        "StreamingEnabled": true,
        "StreamingMinRadius": 768,
        "StreamingTargetRadius": 1536,
        "StreamingIntegrityMode": "Disabled"
      },
      "$ignoreUnknownInstances": true,
      "SurviveAtSeaLobby": {
        "$path": "src/map/SurviveAtSeaLobby.model.json"
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [0.2, 0.35, 0.42],
        "Brightness": 3,
        "ClockTime": 16.5,
        "FogColor": [0.27, 0.55, 0.66],
        "FogEnd": 2200,
        "FogStart": 280,
        "GlobalShadows": true,
        "Outlines": false,
        "OutdoorAmbient": [0.35, 0.55, 0.63],
        "Technology": "ShadowMap"
      },
      "Atmosphere": {
        "$className": "Atmosphere",
        "$properties": {
          "Density": 0.32,
          "Offset": 0.25,
          "Color": [0.78, 0.83, 0.87],
          "Decay": [0.36, 0.46, 0.55],
          "Glare": 0.25,
          "Haze": 1.6
        }
      },
      "Sky": {
        "$className": "Sky",
        "$properties": {
          "SunAngularSize": 12,
          "StarCount": 3000
        }
      },
      "SunRays": {
        "$className": "SunRaysEffect",
        "$properties": {
          "Intensity": 0.18,
          "Spread": 0.85
        }
      },
      "SeaGrade": {
        "$className": "ColorCorrectionEffect",
        "$properties": {
          "Brightness": 0.0,
          "Contrast": 0.08,
          "Saturation": 0.12,
          "TintColor": [0.98, 1.0, 1.0]
        }
      }
    },

    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
