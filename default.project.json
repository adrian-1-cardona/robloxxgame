{
  "name": "SurviveAtSea",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      }
    },

    "ServerScriptService": {
      "SurviveAtSea": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      },
      "$properties": {
        "CameraMaxZoomDistance": 120,
        "CameraMinZoomDistance": 0.5
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "$ignoreUnknownInstances": true,
      "SurviveAtSeaLobby": {
        "$path": "src/map/SurviveAtSeaLobby.model.json"
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [0.2, 0.35, 0.42],
        "Brightness": 3,
        "ClockTime": 16.5,
        "FogColor": [0.27, 0.55, 0.66],
        "FogEnd": 2200,
        "FogStart": 280,
        "GlobalShadows": true,
        "Outlines": false,
        "OutdoorAmbient": [0.35, 0.55, 0.63],
        "Technology": "Voxel"
      }
    },

    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
